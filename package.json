{
  "name": "mikolo-tshirts",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n API,WEB -c blue,magenta \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "seed": "npm run seed -w apps/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
